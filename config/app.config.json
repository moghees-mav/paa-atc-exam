{
  "_instructions": "Edit this file to configure the application.",
  "app": {
    "title": "PAA IIAP ATC EXAM SIMULATOR",
    "subtitle": "Practice Examination for Air Traffic Services Personnel",
    "organization": "PAKISTAN AIRPORTS AUTHORITY",
    "logo_path": "assets/logo.png",
    "version": "1.0.0"
  },
  "ui": {
    "font_family": "Arial, Helvetica, sans-serif",
    "font_size_base": "14px",
    "font_size_min": "12px",
    "theme": "light",
    "primary_color": "#1a3a5c",
    "accent_color": "#2980b9",
    "pass_color": "#27ae60",
    "fail_color": "#c0392b",
    "warn_color": "#e67e22"
