    "flag_questions": true,
    "show_source_tags": true,
    "difficulty_distribution": {
      "easy": 0.5,
      "medium": 0.3,
      "hard": 0.2
    }
  },
  "database": {
    "questions_path": "data/questions.json",
    "difficulty_levels": ["easy", "medium", "hard"],
    "sources": ["bank", "generated"]
